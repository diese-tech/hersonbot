DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hersonbot

CHAT_PROVIDER=local
CHAT_BASE_URL=http://localhost:11434/v1
CHAT_MODEL=llama3
CHAT_API_KEY=ollama

EMBEDDING_PROVIDER=local
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_API_KEY=ollama

OPENAI_API_KEY=

# Vision model — for Visual Context Agent (runs on personal machine)
# llava:13b or llama3.2-vision via local Ollama; fallback to gpt-4o for vision
VISION_BASE_URL=http://localhost:11434/v1
VISION_MODEL=llava:13b
VISION_API_KEY=ollama

# Audio transcription — Whisper (local binary path or remote API)
# Set WHISPER_MODE=local to use whisper.cpp, or WHISPER_MODE=api for OpenAI Whisper API
WHISPER_MODE=local
WHISPER_BINARY=/usr/local/bin/whisper-cpp
# OPENAI_WHISPER_API_KEY=   # only needed if WHISPER_MODE=api

# Visual ingestion controls (personal machine only)
FRAME_INTERVAL_SECONDS=30
YOUTUBE_API_KEY=             # required for playlist enumeration (YouTube Data API v3)
